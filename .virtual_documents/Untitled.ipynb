import pandas as pd

pd.set_option('display.max_columns', None)


df1 = pd.read_csv(r"data/Datos_Ventas_Tienda.csv")
df1


df2 = pd.read_csv(r"data/Datos_Ventas_Tienda2.csv")
df2





df_combined = pd.concat([df1, df2], ignore_index=True)
names2 = ["Date", "Product","Quantity", "Price Per Unit", "Total"]
df_combined.columns = names2
df_combined


df_combined.info()






df_combined["Date"] = pd.to_datetime(df_combined["Date"])
df_combined.info()





df_combined["Month"] = df_combined["Date"].dt.month_name()
df_group_sales = df_combined.groupby("Month")["Total"].sum().sort_values(ascending=False)
df_group_sales.head(1)





df_group_product = df_combined.groupby("Product")["Quantity"].sum().sort_values(ascending = False)
df_group_product.head(1)


df_group_cathegory = df_combined.groupby("Product")["Total"].sum()
df_group_cathegory



